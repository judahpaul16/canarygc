# Path to the SQLite database file (created on first boot).
DATABASE_PATH=./src/data.db

# OpenAIP API key for worldwide airspace overlays and no-fly-zone safety
# checks. Free key from https://www.openaip.net. When blank, airspace falls
# back to the FAA's keyless public layers, which cover the US.
OPENAIP_API_KEY=

# Altitude Angel API key for the /api/altitudeangel airspace endpoint (optional).
VITE_ALTITUDE_ANGEL_API_KEY=

# Serial device of a Betaflight or INAV flight controller for the Firmware tab
# (MSP detection and telemetry). Leave blank to keep the FC panel disabled.
MSP_SERIAL_PATH=
MSP_BAUD=115200

# Alternatively, reach an MSP flight controller over TCP: a SITL build or a
# serial-over-TCP bridge. The development-betaflight and development-inav compose
# profiles point these at the bundled SITL automatically.
MSP_TCP_HOST=
MSP_TCP_PORT=

# Serial device the Firmware tab flashes ArduPilot and PX4 over; defaults to
# the MAVLink autopilot's serial port, which doubles as its bootloader.
FC_BOOTLOADER_PATH=/dev/ttyACM0

# In development the MAVLink link dials a TCP SITL at this host and port
# (defaults below). A blank host disables the link, which the
# development-betaflight and development-inav profiles use because they carry an
# MSP flight controller, not a MAVLink vehicle.
# MAVLINK_TCP_HOST=sitl
# MAVLINK_TCP_PORT=5760
