# Copy this file to .env in the repo root. This single file feeds both Docker
# Compose (the host ports and services below, substituted into
# docker-compose.yml) and the app container (the application configuration at
# the bottom, injected as environment by docker-compose.yml). Every value has a
# default, so the stack runs without a .env at all.

# ── Docker Compose: host ports and services ─────────────────────────────────

# Host port overrides. Defaults are shown; set a value only to avoid a
# collision with another local stack.
APP_DEV_PORT=5173
SITL_PORT=5760
# Host port for the Betaflight/INAV SITL MSP link (development-betaflight and
# development-inav profiles).
MSP_PORT=5761
APP_PORT=3000

# Host port the production nginx reverse proxy serves the app on, so the station
# answers at its hostname with no port. The app container's own port is APP_PORT.
HTTP_PORT=80

# Which ArduPilot vehicle the `development` profile SITL simulates. Defaults to a
# multirotor. Set both to fly a rover, submarine, or plane and exercise the
# vehicle-specific controls (a submarine gets a depth control, a rover drops the
# vertical control):
#   SITL_VEHICLE=Rover     SITL_MODEL=rover
#   SITL_VEHICLE=ArduSub   SITL_MODEL=vectored
#   SITL_VEHICLE=ArduPlane SITL_MODEL=plane
SITL_VEHICLE=ArduCopter
SITL_MODEL=quad

# Live-feed video source for the MediaMTX `cam` path (production profile). One of:
#   rpiCamera                          Raspberry Pi CSI camera (default)
#   rtsp://user:pass@host:554/stream   an RTSP, RTMP, or SRT URL: an IP camera,
#                                      a companion computer, or a flight
#                                      controller camera that advertises RTSP
#   publisher                          a USB/V4L2 capture device; also set
#                                      WEBRTC_RUNONDEMAND. This is how analog FPV
#                                      (a USB analog capture dongle) or digital
#                                      FPV (HDZero/DJI/Walksnail over an HDMI
#                                      grabber) enters, including a Betaflight
#                                      board's FPV feed, which has no IP output.
WEBRTC_SOURCE=rpiCamera

# The command MediaMTX runs to publish `cam` when WEBRTC_SOURCE=publisher. For a
# V4L2 capture device at /dev/video0:
#   ffmpeg -f v4l2 -framerate 30 -video_size 720x480 -i /dev/video0 -c:v libx264 -preset ultrafast -tune zerolatency -pix_fmt yuv420p -f rtsp rtsp://localhost:8554/cam
WEBRTC_RUNONDEMAND=

# MediaMTX control-API base URL the app patches when the camera source is changed
# in Integrations. Defaults to the host-network MediaMTX reached over the docker
# host gateway; WEBRTC_SOURCE remains the boot default the bridge starts with.
MEDIAMTX_API_URL=http://host.docker.internal:9997

# ── Application configuration (injected into the app container) ──────────────

# Path to the SQLite database file (created on first boot). Left unset here so
# each compose face uses its own default: the dev source tree (./src/data.db)
# and the production image path (/app/src/data.db). Set it only to relocate the
# database.
# DATABASE_PATH=

# OpenAIP API key for worldwide airspace overlays and no-fly-zone safety
# checks. Free key from https://www.openaip.net. When blank, airspace falls
# back to the FAA's keyless public layers, which cover the US.
OPENAIP_API_KEY=

# Altitude Angel API key for the /api/altitudeangel airspace endpoint (optional).
VITE_ALTITUDE_ANGEL_API_KEY=

# MapTiler API key for the rich dark basemap and labeled hybrid satellite.
# Without it the map falls back to keyless tile sources. Also settable in
# Integrations, which takes precedence.
MAPTILER_KEY=

# AI PID tuning assistant: any OpenAI-compatible endpoint (OpenAI, a LiteLLM
# proxy, or a local Ollama). Blank values fall back to the defaults
# (https://api.openai.com/v1, gpt-4o-mini). Also settable in Integrations.
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# MAVLink 2 signing passphrase. When set, the link signs outbound messages and
# verifies inbound ones. Also settable in Integrations.
MAVLINK_SIGNING_KEY=

# SMTP for password-reset and alert email. Port defaults to 587; set
# SMTP_SECURE=true for implicit TLS on port 465. MAIL_FROM defaults to
# SMTP_USER. Also settable in Integrations, which takes precedence.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Serial device of the MAVLink autopilot. Blank scans the serial ports for
# MAVLink traffic and locks onto the first one carrying it. Set a path to pin
# the link, /dev/ttyAMA0 for a TELEM2 UART hookup at 921600.
MAVLINK_SERIAL_PATH=
MAVLINK_BAUD=115200

# Serial device of a Betaflight or INAV flight controller for the Firmware tab
# (MSP detection and telemetry). Leave blank to keep the FC panel disabled.
MSP_SERIAL_PATH=
MSP_BAUD=115200

# Alternatively, reach an MSP flight controller over TCP: a SITL build or a
# serial-over-TCP bridge. The development-betaflight and development-inav compose
# profiles point these at the bundled SITL automatically.
MSP_TCP_HOST=
MSP_TCP_PORT=

# Serial device the Firmware tab flashes ArduPilot and PX4 over; defaults to
# the MAVLink autopilot's serial port, which doubles as its bootloader.
FC_BOOTLOADER_PATH=/dev/ttyACM0

# Directory for recorded flight logs. Left unset so each compose face uses its
# own default: ./flight-logs in development and /app/src/flight-logs (inside
# the data volume) in production. Set it only to relocate the logs.
# FLIGHT_LOG_PATH=

# In development the MAVLink link dials a TCP SITL at this host and port
# (defaults below). A blank host disables the link, which the
# development-betaflight and development-inav profiles use because they carry an
# MSP flight controller, not a MAVLink vehicle.
# MAVLINK_TCP_HOST=sitl
# MAVLINK_TCP_PORT=5760
