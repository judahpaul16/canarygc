# Host port overrides for docker-compose. Defaults are shown; set a value
# only to avoid a collision with another local stack.
APP_DEV_PORT=5173
SITL_PORT=5760
# Host port for the Betaflight/INAV SITL MSP link (development-betaflight and
# development-inav profiles).
MSP_PORT=5761
APP_PORT=3000

# Which ArduPilot vehicle the `development` profile SITL simulates. Defaults to a
# multirotor. Set both to fly a rover, submarine, or plane and exercise the
# vehicle-specific controls (a submarine gets a depth control, a rover drops the
# vertical control):
#   SITL_VEHICLE=Rover     SITL_MODEL=rover
#   SITL_VEHICLE=ArduSub   SITL_MODEL=vectored
#   SITL_VEHICLE=ArduPlane SITL_MODEL=plane
SITL_VEHICLE=ArduCopter
SITL_MODEL=quad

# Image the production app service runs. Defaults to a local build.
CANARYGC_IMAGE=canarygc-app

# Live-feed video source for the MediaMTX `cam` path (production profile). One of:
#   rpiCamera                          Raspberry Pi CSI camera (default)
#   rtsp://user:pass@host:554/stream   an RTSP, RTMP, or SRT URL: an IP camera,
#                                      a companion computer, or a flight
#                                      controller camera that advertises RTSP
#   publisher                          a USB/V4L2 capture device; also set
#                                      WEBRTC_RUNONDEMAND. This is how analog FPV
#                                      (a USB analog capture dongle) or digital
#                                      FPV (HDZero/DJI/Walksnail over an HDMI
#                                      grabber) enters, including a Betaflight
#                                      board's FPV feed, which has no IP output.
WEBRTC_SOURCE=rpiCamera

# The command MediaMTX runs to publish `cam` when WEBRTC_SOURCE=publisher. For a
# V4L2 capture device at /dev/video0:
#   ffmpeg -f v4l2 -framerate 30 -video_size 720x480 -i /dev/video0 -c:v libx264 -preset ultrafast -tune zerolatency -pix_fmt yuv420p -f rtsp rtsp://localhost:8554/cam
WEBRTC_RUNONDEMAND=

# MediaMTX control-API base URL the app patches when the camera source is changed
# in Integrations. Defaults to the host-network MediaMTX reached over the docker
# host gateway; WEBRTC_SOURCE remains the boot default the bridge starts with.
MEDIAMTX_API_URL=http://host.docker.internal:9997
